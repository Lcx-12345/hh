{
  "name": "file-format-detector",
  "display_name": "文件格式检测器",
  "description": "检测文件格式，特别是图片文件格式",
  "author": "Trae Assistant",
  "version": "1.0.0",
  "triggers": {
    "keywords": ["图片", "image", "图片文件", "image file", "文件格式", "file format"],
    "patterns": ["识别.*图片", "检测.*图片", "图片.*格式", "image.*format"]
  },
  "capabilities": ["file_format_detection", "image_detection"],
  "inputs": {
    "file_path": {
      "type": "string",
      "description": "文件路径",
      "required": true
    }
  },
  "outputs": {
    "file_format": {
      "type": "string",
      "description": "文件格式"
    },
    "is_image": {
      "type": "boolean",
      "description": "是否为图片文件"
    },
    "image_type": {
      "type": "string",
      "description": "图片类型"
    }
  },
  "example_usage": [
    {
      "input": {"file_path": "/path/to/image.jpg"},
      "output": {
        "file_format": "JPEG",
        "is_image": true,
        "image_type": "JPEG"
      }
    }
  ]
}
